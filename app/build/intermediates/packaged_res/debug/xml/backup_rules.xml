<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!--
   Sample backup rules file. The default rules will back up all of your files except
   those in the "cache" and "tmp" directories, and excluding "managed_profiles"
   database, and only if the device is charging (to conserve battery, as backing up
   can be power-intensive).

   If you have complex backup requirements, you can further customize the rules.
   -->

    <include domain="sharedpref" path="." />
    <exclude domain="sharedpref" path="device_preferences.xml" />
</full-backup-content>
